# Local overrides for development (not committed to production).
# Loaded by scripts/dev-backend.ps1 and scripts/dev-backend-sqlserver.ps1.

# Prevent first-request cold-start timeouts when Ollama is loading a model.
PFE_LLM_TIMEOUT_SECONDS=120

# Keep the model loaded in memory to avoid repeated cold starts.
PFE_LLM_KEEP_ALIVE=30m

# Optional: smaller answers = faster responses
PFE_LLM_MAX_TOKENS=160
PFE_LLM_CONTEXT=1024

